# Authentication is handled by iron-proxy's gcp_auth transform (see
# [tool.centaur].secrets in pyproject.toml). The proxy loads this
# service-account keyfile, mints a short-lived OAuth2 access token for the
# logging.read scope, and injects it on outbound Google API requests. The tool
# itself sends no credentials.
GCP_LOGS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"..."}
