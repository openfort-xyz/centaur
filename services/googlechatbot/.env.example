PORT=3002
NODE_ENV="development"
COMMIT_SHA="local"

# Google service account key (raw JSON). Grants the bot the chat.bot scope to
# post/edit messages and chat.app.messages.readonly to read thread history.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"...@...iam.gserviceaccount.com"}

# api-rs (Rust Centaur API) the bot drives sessions against.
CENTAUR_API_URL="http://127.0.0.1:8080"
# Bearer token for api-rs (preferred); CENTAUR_API_KEY is the fallback.
GOOGLECHATBOT_API_KEY=""
CENTAUR_API_KEY=""

CHAT_EVENTS_PATH="/api/chat/events"
CHAT_EVENT_DEDUP_TTL_MS="600000"
CHAT_EVENT_MAX_AGE_SECONDS="300"

# Comma/space-separated email-domain allowlist. Empty = open to all domains.
GOOGLECHATBOT_ALLOWED_DOMAIN="openfort.xyz"

# Workspace user the service account impersonates for attachment uploads
# (media.upload rejects app auth). Requires a domain-wide-delegation grant of
# chat.messages.create to the SA's client ID. Empty = uploads fail closed.
GOOGLECHATBOT_UPLOAD_USER=""

# Optional per-run guards forwarded to api-rs.
SESSION_IDLE_TIMEOUT_MS=""
SESSION_MAX_DURATION_MS=""
